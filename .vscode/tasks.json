{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "go: fmt",
      "type": "shell",
      "command": "gofmt -w .",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "go: vet",
      "type": "shell",
      "command": "go vet ./...",
      "problemMatcher": ["$go"],
      "group": "build"
    },
    {
      "label": "go: test",
      "type": "shell",
      "command": "go test ./...",
      "problemMatcher": ["$go"],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "go: build",
      "type": "shell",
      "command": "go build ./cmd/servervault",
      "problemMatcher": ["$go"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "shell: syntax check",
      "type": "shell",
      "command": "bash -n bin/* install.sh",
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "shell: shellcheck",
      "type": "shell",
      "command": "shellcheck bin/* install.sh",
      "problemMatcher": [],
      "group": "test"
    }
  ]
}
