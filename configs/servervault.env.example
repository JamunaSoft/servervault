# Restic repository. Example:
# sftp:u123456@u123456.your-storagebox.de:/backups/servervault
RESTIC_REPOSITORY="sftp:USER@HOST:/backups/servervault"
RESTIC_PASSWORD_FILE="/root/.config/restic/servervault-password"

# Optional SSH command for Restic SFTP backend.
RESTIC_SFTP_COMMAND="ssh -i /root/.ssh/servervault_backup -o IdentitiesOnly=yes"

POSTGRES_DATABASE="app_production"
POSTGRES_USER="postgres"

BACKUP_ROOT="/var/backups/servervault"
RESTORE_ROOT="/var/restore/servervault"
EXCLUDES_FILE="/etc/servervault/excludes.txt"

BACKUP_PATHS="/var/www /etc/nginx /etc/postgresql /etc/php /etc/systemd/system /etc/cron.d /etc/letsencrypt"

KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=12

ZSTD_LEVEL=10
SERVER_TAG="$(hostname -s)"
